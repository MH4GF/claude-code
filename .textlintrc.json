{
  "plugins": {
    "@textlint/markdown": {
      "extensions": [".mdx"]
    }
  },
  "rules": {
    "preset-ja-technical-writing": {
      "ja-no-mixed-period": false,
      "sentence-length": {
        "max": 130
      }
    },
    "@textlint-ja/preset-ai-writing": true,
    "no-mid-sentence-break": true,
    "prh": {
      "rulePaths": ["./prh.yml"]
    }
  }
}
